# Скопировать как .env ЛОКАЛЬНО (в git не попадёт). В Railway — задать в env сервиса api.
BOT_TOKEN=
DATABASE_URL=
OWNER_ID=7180071033
CORS_ORIGIN=*

# ── Слой 2: аутентификация ───────────────────────────────────────────────────
# supervisor-аккаунт создаётся автоматически при первом старте, если users пуста.
OWNER_EMAIL=
OWNER_INITIAL_PASSWORD=
OWNER_FULL_NAME=
# Секрет подписи JWT: сгенерировать через  openssl rand -hex 32
JWT_SECRET=

# ── Gemini (распознавание чеков) ─────────────────────────────────────────────
GEMINI_API_KEY=
# 7g: модель можно сменить без редеплоя (при бане/смене квоты). Дефолт gemini-2.0-flash.
GEMINI_MODEL=gemini-2.0-flash

# ── Прод: CORS сузить до домена Vercel (не оставлять * на бою) ────────────────
# CORS_ORIGIN=https://hours-calculator-neon.vercel.app
