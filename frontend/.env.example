# Скопировать как .env.local ЛОКАЛЬНО (в git не попадёт). В Vercel — задать в env проекта.
VITE_API_URL=

# Только для отладки в обычном браузере (вне Telegram):
# вставить РЕАЛЬНО подписанную тестовую initData (получить из Telegram один раз).
# Иначе API вернёт 401 (подпись не сойдётся) — это ожидаемо. В Telegram это поле НЕ нужно.
VITE_MOCK_INIT_DATA=
